{
  "$schema": "https://json-schema.org/schema",
  "$id": "UiLibrary",
  "title": "UI Library Generator",
  "description": "Generate an Angular UI library with a standalone component and component harness",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the component (e.g. 'card', 'button')",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What is the component name?"
    },
    "scope": {
      "type": "string",
      "description": "The domain scope for the library (e.g. 'shared', 'comics')",
      "default": "shared"
    }
  },
  "required": ["name"]
}
